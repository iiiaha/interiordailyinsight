# 네이버 로그인 (카페 크롤링용)
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password

# 네이버 검색 API (선택 - 크롤링 대신 사용 시)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key

# SendGrid 이메일
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=insight@yourdomain.com
SENDGRID_FROM_NAME=인테리어 인사이트 위클리

# Supabase
# SUPABASE_KEY: anon key (브라우저용, 랜딩 가입폼)
# SUPABASE_SERVICE_ROLE_KEY: service_role key (백엔드용, RLS 우회)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 리포트 스케줄 설정
REPORT_SEND_DAY=monday
REPORT_SEND_HOUR=9

# 서비스 설정
SERVICE_DOMAIN=https://yourdomain.com
LOG_LEVEL=INFO
